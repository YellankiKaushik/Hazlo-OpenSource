# Hazlo environment template
# Copy to .env.local for local frontend work, or configure the same values in Vercel.

# Server-side Vercel environment variables
NOTION_TOKEN=your_notion_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
API_SECRET=your_random_api_secret_here

# Frontend environment variables
VITE_API_SECRET=your_same_random_api_secret_here

# Optional: leave empty when the frontend and /api routes share the same origin.
VITE_API_BASE_URL=
