{
    "name": "hazlo",
    "private": true,
    "description": "Voice-first task capture app with local extraction and Notion sync.",
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "preview": "vite preview",
        "vercel:pull": "vercel pull --yes --environment=development",
        "dev:vercel": "npm run vercel:pull && vercel dev",
        "deploy:vercel": "vercel --prod"
    },
    "dependencies": {
        "lucide-react": "^0.533.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "zustand": "^4.4.7"
    },
    "devDependencies": {
        "@types/node": "^24.0.14",
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.5.2",
        "@youware/vite-plugin-react": "^1.0.3",
        "autoprefixer": "^10.4.21",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.17",
        "typescript": "~5.8.3",
        "vite": "^7.0.0",
        "vitest": "^4.1.9"
    }
}
